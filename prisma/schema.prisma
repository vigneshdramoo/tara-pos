generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum InventoryMovementType {
  SALE
  RESTOCK
  ADJUSTMENT
  SEED
}

enum StaffRole {
  MANAGER
  SALES_MANAGER
  CASHIER
}

enum QuizLeadSource {
  POPUP_BOOTH
  WEBSITE
  QUIZ
  INSTAGRAM
  WHATSAPP
  OTHER
}

enum PurchaseIntent {
  BUY_TODAY
  BUY_LATER
  DISCOVERY_PACK
  JUST_EXPLORING
  GIFTING
}

model Product {
  id                 String              @id @default(cuid())
  slug               String              @unique
  sku                String              @unique
  name               String
  collection         String
  description        String
  notes              String
  mood               String
  sizeMl             Int
  priceCents         Int
  stock              Int
  reorderLevel       Int
  accentHex          String              @default("#C7A27C")
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  orderItems         OrderItem[]
  inventoryMovements InventoryMovement[]
}

model Customer {
  id        String     @id @default(cuid())
  name      String
  email     String?    @unique
  phone     String?    @unique
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  orders    Order[]
  quizLeads QuizLead[]
}

model Order {
  id                 String              @id @default(cuid())
  orderNumber        String              @unique
  subtotalCents      Int
  taxCents           Int
  totalCents         Int
  commissionCents    Int                 @default(0)
  paymentMethod      PaymentMethod
  notes              String?
  customerId         String?
  salespersonId      String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  salesperson        StaffUser?          @relation("SalespersonOrders", fields: [salespersonId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  inventoryMovements InventoryMovement[]

  @@index([createdAt])
  @@index([customerId])
  @@index([salespersonId])
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  productId         String
  quantity          Int
  unitPriceCents    Int
  totalPriceCents   Int
  commissionRateBps Int      @default(0)
  commissionCents   Int      @default(0)
  createdAt         DateTime @default(now())
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model InventoryMovement {
  id            String                @id @default(cuid())
  productId     String
  orderId       String?
  type          InventoryMovementType
  quantityDelta Int
  note          String?
  createdAt     DateTime              @default(now())
  product       Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  order         Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([orderId])
}

model StaffUser {
  id           String    @id @default(cuid())
  name         String
  username     String    @unique
  email        String?   @unique
  passwordHash String
  role         StaffRole
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  ordersSold   Order[]   @relation("SalespersonOrders")
}

model QuizLead {
  id                  String         @id @default(cuid())
  leadNumber          String         @unique
  name                String?
  email               String?
  phone               String?
  ageRange            String?
  genderIdentity      String?
  city                String?
  eventName           String?
  source              QuizLeadSource @default(POPUP_BOOTH)
  resultScent         String
  secondaryScent      String?
  purchaseIntent      PurchaseIntent @default(JUST_EXPLORING)
  marketingConsent    Boolean        @default(false)
  answers             Json?
  scores              Json?
  notes               String?
  convertedCustomerId String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  convertedCustomer   Customer?      @relation(fields: [convertedCustomerId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([resultScent])
  @@index([source])
  @@index([purchaseIntent])
  @@index([convertedCustomerId])
}
